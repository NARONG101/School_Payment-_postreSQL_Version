# ── Application ──────────────────────────────────────────────
APP_NAME="Student Payment System"
APP_ENV=production
# Generate with: php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────
# Use 'stderr' on Render so logs appear in the dashboard
LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Database ─────────────────────────────────────────────────
# SQLite (default — file persisted via Render Disk)
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

# MySQL / PostgreSQL (uncomment and fill if using an external DB)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=student_payment
# DB_USERNAME=root
# DB_PASSWORD=

# ── Session / Cache / Queue ───────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@yourschool.edu"
MAIL_FROM_NAME="${APP_NAME}"

# ── File Storage ─────────────────────────────────────────────
FILESYSTEM_DISK=public

# ── Render-specific ──────────────────────────────────────────
# Set RENDER=true in Render environment variables
RENDER=false

# ── Admin Seeder (used on first boot) ────────────────────────
ADMIN_EMAIL=admin@school.edu
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME="Admin User"
